# CosherAlert — environment variables template
# Copy to .env and fill in your values

YEMOT_SYSTEM_ID=            # Yemot system number (e.g. 0772221657)
YEMOT_PASSWORD=             # Yemot admin password
YEMOT_CALLER_ID_A=          # Phone number for pre-warning tzintuqim (Phase 1)
YEMOT_CALLER_ID_B=          # Phone number for siren calls (Phase 2, leave blank)

OREF_POLL_INTERVAL=5        # Polling interval in seconds
DB_PATH=cosherlert.db       # Path to SQLite database
IVR_WEBHOOK_PORT=8443       # Flask IVR webhook port
IVR_BASE_URL=               # Public HTTPS base URL for IVR webhooks (e.g. https://1.2.3.4)
LOG_LEVEL=INFO
